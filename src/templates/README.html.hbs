<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{title}} - {{i18n.documentation}}</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;color:#1a1a2e;background:#f5f7fa;line-height:1.7}
.hero{text-align:center;padding:60px 20px;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:#fff}
.hero h1{font-size:2.4em;margin-bottom:12px}
.hero .version{opacity:.85;font-size:1.1em}
.hero .desc{max-width:640px;margin:20px auto 0;opacity:.9}
.container{max-width:1100px;margin:0 auto;padding:40px 20px;display:flex;gap:30px}
.main{flex:1;min-width:0}
.sidebar{width:260px;flex-shrink:0}
.sidebar nav{position:sticky;top:20px;background:#fff;border-radius:12px;padding:20px;box-shadow:0 2px 12px rgba(0,0,0,.08)}
.sidebar h3{font-size:.85em;text-transform:uppercase;color:#888;margin-bottom:12px;letter-spacing:1px}
.sidebar a{display:block;padding:6px 0;color:#4a5568;text-decoration:none;font-size:.95em}
.sidebar a:hover{color:#667eea}
.card{background:#fff;border-radius:12px;padding:28px;margin-bottom:24px;box-shadow:0 2px 12px rgba(0,0,0,.06)}
.card h2{font-size:1.3em;margin-bottom:16px;color:#2d3748;border-bottom:2px solid #edf2f7;padding-bottom:10px}
table{width:100%;border-collapse:collapse}
th,td{padding:10px 14px;text-align:left;border-bottom:1px solid #edf2f7}
th{background:#f8fafc;font-weight:600;color:#4a5568;font-size:.9em}
code{background:#edf2f7;padding:2px 6px;border-radius:4px;font-size:.9em;color:#e53e3e}
.footer{text-align:center;padding:30px;color:#a0aec0;font-size:.9em}
@media(max-width:768px){.container{flex-direction:column}.sidebar{width:100%}.hero h1{font-size:1.8em}}
</style>
</head>
<body>
<div class="hero">
  <h1>{{title}}</h1>
  <div class="version">v{{version}}</div>
  {{#if description}}<div class="desc">{{description}}</div>{{/if}}
</div>
<div class="container">
  <div class="main">
    {{#if servers}}
    <div class="card">
      <h2>🌐 {{i18n.servers}}</h2>
      <table><tr><th>URL</th><th>{{i18n.overview}}</th></tr>
      {{#each servers}}<tr><td><code>{{{url}}}</code></td><td>{{#if description}}{{description}}{{else}}-{{/if}}</td></tr>{{/each}}
      </table>
    </div>
    {{/if}}
    <div class="card">
      <h2>📄 {{i18n.documentation}}</h2>
      <table>
        <tr><td>📘</td><td><a href="./API.html">{{i18n.apiReference}}</a></td></tr>
        {{#if hasTags}}
        <tr><td>🏷️</td><td><a href="./Tags.html">{{i18n.tags}}</a></td></tr>
        {{/if}}
        <tr><td>🗂️</td><td><a href="./Schemas.html">{{i18n.dataSchemas}}</a></td></tr>
      </table>
    </div>
    {{#if contact}}
    <div class="card">
      <h2>📞 {{i18n.contact}}</h2>
      <p>{{#if contact.name}}<strong>{{contact.name}}</strong><br>{{/if}}
      {{#if contact.email}}📧 {{contact.email}}<br>{{/if}}
      {{#if contact.url}}🔗 {{contact.url}}{{/if}}</p>
    </div>
    {{/if}}
    {{#if license}}
    <div class="card">
      <h2>📋 {{i18n.license}}</h2>
      <p>{{#if license.url}}<a href="{{{license.url}}}">{{license.name}}</a>{{else}}{{license.name}}{{/if}}</p>
    </div>
    {{/if}}
  </div>
  <div class="sidebar">
    <nav>
      <h3>{{i18n.overview}}</h3>
      <a href="#">{{i18n.overview}}</a>
      <a href="./API.html">{{i18n.apiReference}}</a>
      {{#if hasTags}}<a href="./Tags.html">{{i18n.tags}}</a>{{/if}}
      <a href="./Schemas.html">{{i18n.dataSchemas}}</a>
    </nav>
  </div>
</div>
<div class="footer">Generated by <a href="https://github.com/Agolid/api-doc-sync">api-doc-sync</a></div>
</body>
</html>
