<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{tagName}} - {{title}}</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;color:#1a1a2e;background:#f5f7fa;line-height:1.7}
.header{background:linear-gradient(135deg,#48bb78 0%,#38a169 100%);color:#fff;padding:30px 20px}
.header h1{font-size:1.8em}
.header .sub{opacity:.8}
.container{max-width:1100px;margin:0 auto;padding:30px 20px;display:flex;gap:30px}
.main{flex:1;min-width:0}
.sidebar{width:260px;flex-shrink:0}
.sidebar nav{position:sticky;top:20px;background:#fff;border-radius:12px;padding:20px;box-shadow:0 2px 12px rgba(0,0,0,.08)}
.sidebar h3{font-size:.8em;text-transform:uppercase;color:#888;margin:16px 0 8px;letter-spacing:1px}
.sidebar a{display:block;padding:4px 0;color:#4a5568;text-decoration:none;font-size:.88em}
.sidebar a:hover{color:#48bb78}
.card{background:#fff;border-radius:12px;padding:24px;margin-bottom:20px;box-shadow:0 2px 12px rgba(0,0,0,.06)}
.method-badge{display:inline-block;padding:3px 10px;border-radius:20px;font-size:.75em;font-weight:700;color:#fff}
.method-get{background:#48bb78}.method-post{background:#4299e1}.method-put{background:#ed8936}.method-delete{background:#fc8181}.method-patch{background:#9f7aea}
.op-title{font-size:1.05em;margin-bottom:8px}
.op-summary{color:#4a5568;margin-bottom:12px}
table{width:100%;border-collapse:collapse;margin:12px 0}
th,td{padding:8px 12px;text-align:left;border-bottom:1px solid #edf2f7;font-size:.9em}
th{background:#f8fafc;font-weight:600;color:#4a5568;font-size:.82em;text-transform:uppercase}
code{background:#edf2f7;padding:2px 6px;border-radius:4px;font-size:.88em;color:#e53e3e}
hr{border:none;border-top:1px solid #edf2f7;margin:20px 0}
.footer{text-align:center;padding:30px;color:#a0aec0;font-size:.85em}
a{color:#667eea}
@media(max-width:768px){.container{flex-direction:column}.sidebar{width:100%}}
</style>
</head>
<body>
<div class="header">
  <a href="./index.html" style="color:#fff;text-decoration:none">← Back</a>
  <h1>🏷️ {{tagName}}</h1>
  <div class="sub">{{i18n.partOf}} {{title}}</div>
</div>
<div class="container">
  <div class="main">
{{#each operations}}
    <div class="card">
      <div class="op-title">
        <span class="method-badge method-{{method}}">{{toUpperCase method}}</span>
        <code>{{path}}</code>
      </div>
      {{#if operation.summary}}<div class="op-summary">{{operation.summary}}</div>{{/if}}
      {{#if operation.description}}<p>{{operation.description}}</p>{{/if}}
      {{#if operation.operationId}}<p style="font-size:.85em;color:#718096">{{i18n.operationId}}: <code>{{operation.operationId}}</code></p>{{/if}}

      {{#if operation.parameters}}
      <h4>{{i18n.parameters}}</h4>
      <table>
        <tr><th>Name</th><th>In</th><th>Type</th><th>{{i18n.required}}</th><th>Description</th></tr>
{{#each operation.parameters}}
        <tr><td><code>{{name}}</code></td><td>{{in}}</td><td>{{type}}</td><td>{{#if required}}✅{{else}}❌{{/if}}</td><td>{{#if description}}{{description}}{{else}}-{{/if}}</td></tr>
{{/each}}
      </table>
      {{/if}}

      {{#if operation.responses}}
      <h4>{{i18n.responses}}</h4>
      <table><tr><th>Status</th><th>Description</th></tr>
{{#each operation.responses}}
        <tr><td><code>{{@key}}</code></td><td>{{description}}</td></tr>
{{/each}}
      </table>
      {{/if}}
    </div>
{{/each}}
  </div>
  <div class="sidebar">
    <nav>
      <h3>{{i18n.tags}}</h3>
{{#each allTags}}
      <a href="./{{slugify name}}.html">{{name}}</a>
{{/each}}
    </nav>
  </div>
</div>
<div class="footer">Generated by <a href="https://github.com/Agolid/api-doc-sync">api-doc-sync</a></div>
</body>
</html>
