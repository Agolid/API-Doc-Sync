<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{title}} - {{i18n.dataSchemas}}</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;color:#1a1a2e;background:#f5f7fa;line-height:1.7}
.header{background:linear-gradient(135deg,#ed8936 0%,#dd6b20 100%);color:#fff;padding:30px 20px}
.header h1{font-size:1.8em}
.header .sub{opacity:.8}
.container{max-width:1100px;margin:0 auto;padding:30px 20px;display:flex;gap:30px}
.main{flex:1;min-width:0}
.sidebar{width:260px;flex-shrink:0}
.sidebar nav{position:sticky;top:20px;background:#fff;border-radius:12px;padding:20px;box-shadow:0 2px 12px rgba(0,0,0,.08);max-height:90vh;overflow-y:auto}
.sidebar h3{font-size:.8em;text-transform:uppercase;color:#888;margin:16px 0 8px;letter-spacing:1px}
.sidebar h3:first-child{margin-top:0}
.sidebar a{display:block;padding:4px 0;color:#4a5568;text-decoration:none;font-size:.88em}
.sidebar a:hover{color:#ed8936}
.card{background:#fff;border-radius:12px;padding:24px;margin-bottom:20px;box-shadow:0 2px 12px rgba(0,0,0,.06)}
.card h2{font-size:1.15em;color:#2d3748;margin-bottom:8px;font-family:'SF Mono',Monaco,Consolas,monospace}
.card .desc{color:#718096;margin-bottom:16px;font-size:.92em}
.card .type-badge{display:inline-block;background:#ebf8ff;color:#3182ce;padding:2px 10px;border-radius:12px;font-size:.82em;margin-bottom:12px}
table{width:100%;border-collapse:collapse;margin:12px 0}
th,td{padding:8px 12px;text-align:left;border-bottom:1px solid #edf2f7;font-size:.9em}
th{background:#f8fafc;font-weight:600;color:#4a5568;font-size:.82em;text-transform:uppercase}
code{background:#edf2f7;padding:2px 6px;border-radius:4px;font-size:.88em;color:#e53e3e}
pre{background:#2d3748;color:#e2e8f0;padding:16px;border-radius:8px;overflow-x:auto;margin:12px 0}
pre code{background:none;color:inherit;padding:0}
.required-list{margin:8px 0;color:#718096;font-size:.88em}
.footer{text-align:center;padding:30px;color:#a0aec0;font-size:.85em}
a{color:#667eea}
@media(max-width:768px){.container{flex-direction:column}.sidebar{width:100%}}
</style>
</head>
<body>
<div class="header">
  <a href="./index.html" style="color:#fff;text-decoration:none">← Back</a>
  <h1>🗂️ {{i18n.dataSchemas}}</h1>
  <div class="sub">{{title}}</div>
</div>
<div class="container">
  <div class="main">
{{#each schemas}}
    <div class="card" id="schema-{{@key}}">
      <h2>{{@key}}</h2>
      {{#if this.description}}<div class="desc">{{{cleanHtml this.description}}}</div>{{/if}}
      {{#if this.type}}<span class="type-badge">{{schemaType this}}</span>{{/if}}

      {{#if this.properties}}
      <table>
        <tr><th>Property</th><th>Type</th><th>{{i18n.required}}</th><th>Description</th></tr>
{{#each this.properties}}
        <tr>
          <td><code>{{@key}}</code></td>
          <td>{{schemaType this}}{{#if (schemaFormat this)}} ({{schemaFormat this}}){{/if}}{{#if this.items}}[{{schemaType this.items}}[]]{{/if}}</td>
          <td>{{#if ../required}}{{#if (contains ../required @key)}}✅{{else}}❌{{/if}}{{else}}❌{{/if}}</td>
          <td>{{{cleanHtml this.description}}}</td>
        </tr>
{{/each}}
      </table>
      {{/if}}

      {{#if this.required}}
      <div class="required-list">{{i18n.requiredFields}}: {{#each this.required}}<code>{{this}}</code>{{#unless @last}}, {{/unless}}{{/each}}</div>
      {{/if}}

      {{#if this.example}}
      <h4>{{i18n.example}}</h4>
      <pre><code>{{{json this.example}}}</code></pre>
      {{/if}}
    </div>
{{/each}}
  </div>
  <div class="sidebar">
    <nav>
      <h3>{{i18n.dataSchemas}}</h3>
{{#each schemas}}
      <a href="#schema-{{@key}}">{{@key}}</a>
{{/each}}
    </nav>
  </div>
</div>
<div class="footer">Generated by <a href="https://github.com/Agolid/api-doc-sync">api-doc-sync</a></div>
</body>
</html>
